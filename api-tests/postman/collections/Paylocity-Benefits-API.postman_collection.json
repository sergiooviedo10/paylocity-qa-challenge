{
  "info": {
    "name": "Paylocity - Benefits Dashboard API Automation (Extended Coverage)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET All Employees",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time is acceptable', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
              "",
              "let data = pm.response.json();",
              "",
              "pm.test('Response is array', function () {",
              "    pm.expect(data).to.be.an('array');",
              "});",
              "",
              "if(data.length > 0){",
              "    pm.test('Employee object structure valid', function () {",
              "        pm.expect(data[0]).to.have.property('id');",
              "        pm.expect(data[0]).to.have.property('firstName');",
              "        pm.expect(data[0]).to.have.property('lastName');",
              "        pm.expect(data[0]).to.have.property('salary');",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Create Employee",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Tony\",\n  \"lastName\": \"Stark\",\n  \"username\": \"tstark{{$timestamp}}\",\n  \"dependants\": 2,\n  \"salary\": 85000\n}"
        },
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Employee created successfully', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let json = pm.response.json();",
              "",
              "pm.environment.set('employeeId', json.id);",
              "",
              "pm.test('ID exists', function () {",
              "    pm.expect(json.id).to.exist;",
              "});",
              "",
              "pm.test('Salary is number', function () {",
              "    pm.expect(json.salary).to.be.a('number');",
              "});",
              "",
              "pm.test('Benefits cost exists', function () {",
              "    pm.expect(json.benefitsCost).to.be.a('number');",
              "});",
              "",
              "pm.test('Net pay exists', function () {",
              "    pm.expect(json.net).to.be.a('number');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Employee by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/Employees/{{employeeId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Employee fetched successfully', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let json = pm.response.json();",
              "",
              "pm.test('Correct employee returned', function () {",
              "    pm.expect(json.id).to.eql(pm.environment.get('employeeId'));",
              "});",
              "",
              "pm.test('Fields are not empty', function () {",
              "    pm.expect(json.firstName).to.not.be.empty;",
              "    pm.expect(json.lastName).to.not.be.empty;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT Update Employee",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"{{employeeId}}\",\n  \"firstName\": \"Tony\",\n  \"lastName\": \"Updated\",\n  \"username\": \"tstarkupdated\",\n  \"dependants\": 4,\n  \"salary\": 95000\n}"
        },
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Employee updated successfully', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let json = pm.response.json();",
              "",
              "pm.test('Last name updated', function () {",
              "    pm.expect(json.lastName).to.eql('Updated');",
              "});",
              "",
              "pm.test('Dependants updated', function () {",
              "    pm.expect(json.dependants).to.eql(4);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE Employee",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/Employees/{{employeeId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Employee deleted', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "NEG - Get Non Existing Employee",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/Employees/999999"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Non-existing employee returns error', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([404,400]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "NEG - Missing Required Fields",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"\",\n  \"username\": \"\"\n}"
        },
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Validation error triggered', function () {",
