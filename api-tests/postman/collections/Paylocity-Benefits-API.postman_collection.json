              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "NEG - Invalid Dependents",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"username\": \"baduser\",\n  \"dependants\": -1,\n  \"salary\": 50000\n}"
        },
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Invalid dependents rejected', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([400,422]);",
              "});"
            ]
          }
        }
      ]
    },
