      "name": "NEG - Dependents Above Max",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Max\",\n  \"lastName\": \"Dependent\",\n  \"username\": \"maxdep\",\n  \"dependants\": 99,\n  \"salary\": 60000\n}"
        },
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Too many dependents rejected', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([400,422]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "NEG - Negative Salary",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Bad\",\n  \"lastName\": \"Salary\",\n  \"username\": \"badsalary\",\n  \"dependants\": 1,\n  \"salary\": -50000\n}"
        },
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Negative salary rejected', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([400,422]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "NEG - Missing Authorization",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unauthorized request blocked', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "NEG - Invalid Authorization",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic invalidtoken"
          }
        ],
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Invalid auth rejected', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([401,403]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "NEG - Invalid HTTP Method",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Basic {{authToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/Employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unsupported method rejected', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([400,404,405]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
